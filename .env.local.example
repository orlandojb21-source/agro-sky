# Copia este archivo a .env.local y completa los valores.
# NEXT_PUBLIC_SUPABASE_URL y NEXT_PUBLIC_SUPABASE_ANON_KEY se sacan de
# Supabase: Project Settings > API Keys (y Data API para la URL).
#
# SUPABASE_SERVICE_ROLE_KEY es secreta: solo se usa en el servidor (pantalla
# de Usuarios, para crear cuentas). NUNCA debe llevar el prefijo NEXT_PUBLIC_
# ni exponerse al navegador.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
